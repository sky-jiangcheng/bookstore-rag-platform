# BookStore Local Platform Environment Variables
# 
# Copy this file to .env and fill in your actual values.
# DO NOT commit .env to Git - it's listed in .gitignore for security.
#
# Last updated: 2026-04-27

# ========================================
# Application Environment
# ========================================

# 运行环境
# Options: free_cloud, development, production
APP_ENV=free_cloud

# ========================================
# Server Configuration
# ========================================

# 应用监听端口（Railway/Fly.io 通常设为 8000）
PORT=8000

# 日志级别
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ========================================
# Security Keys
# ========================================

# JWT 签名密钥（必需）
# 生成方式: openssl rand -hex 32
# 长度最少 32 个字符，必须是随机字符串
JWT_SECRET_KEY=your-secret-jwt-key-generated-by-openssl

# 管理员初始密码（必需）
# 首次登录后请立即修改
ADMIN_PASSWORD=your-secure-admin-password

# ========================================
# Database Configuration
# ========================================

# PostgreSQL 连接字符串（必需，或使用 SQLite）
# Format: postgresql://user:password@host:port/database
# 或 sqlite:///path/to/database.db
DATABASE_URL=postgresql://user:password@localhost:5432/bookstore

# 是否启用数据库连接池
# Options: true, false
DATABASE_POOL_ENABLED=true

# 数据库连接池大小
DATABASE_POOL_SIZE=10

# ========================================
# Vector Database (Qdrant)
# ========================================

# Qdrant 向量数据库 URL（必需）
# 本地: http://localhost:6333
# 云端: https://xxx-xxx-xxx.qdrant.io:6333
QDRANT_URL=http://localhost:6333

# Qdrant API 密钥（如果启用认证）
# 云端部署通常需要
QDRANT_API_KEY=your-qdrant-api-key

# Qdrant 集合名称
# 默认: books
QDRANT_COLLECTION_NAME=books

# ========================================
# Cache & Message Queue (Redis)
# ========================================

# Upstash Redis URL（可选，用于分布式缓存）
# Format: redis://default:password@host:port
# 如果不设置，将使用本地内存缓存
UPSTASH_REDIS_URL=redis://default:your-password@upstash-host:port

# 本地开发时 Redis 连接字符串（可选）
# 如果 UPSTASH_REDIS_URL 不设置，使用此项
REDIS_URL=redis://localhost:6379

# ========================================
# CORS Configuration
# ========================================

# 允许的跨域来源（必需）
# 多个域名用逗号分隔，不要设置为 *
# 生产环境必须指定具体域名
# 例: https://bookstore.example.com, https://admin.example.com
CORS_ORIGINS=http://localhost:3000, http://localhost:8000

# ========================================
# AI Model API Keys
# ========================================

# Google Gemini API 密钥（至少配置一个）
GEMINI_API_KEY=your-google-gemini-api-key

# OpenAI API 密钥（可选备选方案）
OPENAI_API_KEY=your-openai-api-key

# 阿里云通义千问 API 密钥（可选备选方案）
QWEN_API_KEY=your-qwen-api-key

# 百度文心一言 API 密钥（可选备选方案）
ERNIE_API_KEY=your-ernie-api-key

# 智谱 GLM API 密钥（可选备选方案）
ZHIPU_API_KEY=your-zhipu-api-key

# 百度文心一言 Secret Key（如使用 ERNIE）
ERNIE_SECRET_KEY=your-ernie-secret-key

# ========================================
# Data Exchange (bookstore-agentic-rag)
# ========================================

# bookstore-agentic-rag 的书单导入服务 URL（可选）
# 用于数据同步和降级兜底
# 例: https://bookstore-agentic-rag.vercel.app/api/v1
CATALOG_SERVICE_URL=http://localhost:3000/api/v1

# ========================================
# Feature Flags
# ========================================

# 是否启用智能推荐功能
ENABLE_RECOMMENDATION=true

# 是否启用向量检索
ENABLE_VECTOR_SEARCH=true

# 是否启用缓存
ENABLE_CACHE=true

# 是否启用速率限制
ENABLE_RATE_LIMIT=true

# ========================================
# Debugging & Development
# ========================================

# 是否启用详细日志（仅开发环境）
DEBUG=false

# 是否启用 Swagger API 文档
# 生产环境建议设为 false
ENABLE_SWAGGER_UI=true

# 是否允许 CORS 预检请求日志
LOG_CORS_PREFLIGHT=false

# ========================================
# Export Configuration
# ========================================

# 书单导出的默认格式
# Options: json, excel, csv
DEFAULT_EXPORT_FORMAT=excel

# 导出文件的最大行数限制
EXPORT_MAX_ROWS=10000

# ========================================
# Email Configuration (Optional)
# ========================================

# SMTP 服务器（如需邮件通知功能）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=noreply@bookstore.example.com

# ========================================
# Third-party Services (Optional)
# ========================================

# Sentry 错误追踪（可选）
SENTRY_DSN=https://your-sentry-dsn

# 用户反馈邮箱
FEEDBACK_EMAIL=feedback@bookstore.example.com

# ========================================
# Notes
# ========================================
#
# 1. 环境变量加载顺序：
#    1) 系统环境变量 (highest priority)
#    2) .env 文件 (this file)
#    3) 代码中的默认值 (lowest priority)
#
# 2. 敏感信息管理：
#    - 永远不要在代码中硬编码密钥
#    - 使用 Railway/Vercel 的 Secrets 管理
#    - 定期轮换 API 密钥
#
# 3. 本地开发：
#    - 使用 .env 文件配置本地环境
#    - 在 .gitignore 中排除 .env 文件
#
# 4. 生产部署：
#    - 使用部署平台的环境变量设置
#    - 不要在仓库中提交敏感信息
#    - 使用强随机字符串作为密钥
#
